USE_LIVE_DATA=true
PUBLIC_STREAMING_ENABLED=true
ENABLE_PRIVATE_WS=true
ENABLE_POLLING_FALLBACK=true

# App Store review mode force-disables transactional server features even if
# individual feature variables below are accidentally set to true.
