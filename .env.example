DATABASE_URL=postgresql://cryptomts:cryptomts@localhost:5432/cryptomts
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-strong-jwt-secret
JWT_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
GOOGLE_IOS_CLIENT_ID=142113558371-t5s22ri6gjl5aur76s81910gf2hb8p09.apps.googleusercontent.com
GOOGLE_WEB_CLIENT_ID=
GOOGLE_CLIENT_IDS=
APPLE_CLIENT_ID=com.hwb.Cryptory
APPLE_CLIENT_IDS=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
PORT=3000
NODE_ENV=development

USE_LIVE_DATA=true
PUBLIC_STREAMING_ENABLED=true
ENABLE_PRIVATE_WS=true
ENABLE_POLLING_FALLBACK=true

USD_KRW_FALLBACK=1350
FX_BASE_URL=https://api.exchangerate.host
FX_STALE_THRESHOLD_MS=300000
MARKET_DATA_STALE_THRESHOLD_MS=300000
FX_TIMESTAMP_SKEW_THRESHOLD_MS=30000
