DATABASE_URL=postgresql://cryptomts:cryptomts@localhost:5432/cryptomts
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-strong-jwt-secret
JWT_EXPIRES_IN=7d
PORT=3000
NODE_ENV=development

USE_LIVE_DATA=true
PUBLIC_STREAMING_ENABLED=true
ENABLE_PRIVATE_WS=true
ENABLE_POLLING_FALLBACK=true

USD_KRW_FALLBACK=1350
FX_BASE_URL=https://api.exchangerate.host
FX_STALE_THRESHOLD_MS=300000
MARKET_DATA_STALE_THRESHOLD_MS=300000
FX_TIMESTAMP_SKEW_THRESHOLD_MS=30000
EXCHANGE_RATE_API_KEY=

EXCHANGE_CREDENTIAL_ENCRYPTION_KEY=replace-with-strong-32-byte-secret

UPBIT_API_BASE_URL=https://api.upbit.com
UPBIT_WS_URL=wss://api.upbit.com/websocket/v1

BITHUMB_API_BASE_URL=https://api.bithumb.com
BITHUMB_WS_URL=wss://ws-api.bithumb.com/websocket/v1

COINONE_API_BASE_URL=https://api.coinone.co.kr
COINONE_WS_URL=wss://stream.coinone.co.kr

KORBIT_API_BASE_URL=https://api.korbit.co.kr
KORBIT_WS_URL=wss://ws-api.korbit.co.kr/v2/public

BINANCE_API_BASE_URL=https://api.binance.com
BINANCE_WS_URL=wss://data-stream.binance.vision/stream

# Optional advanced private websocket overrides.
UPBIT_PRIVATE_WS_URL=wss://api.upbit.com/websocket/v1/private
BITHUMB_PRIVATE_WS_URL=wss://ws-api.bithumb.com/websocket/v1/private
COINONE_PRIVATE_WS_URL=wss://stream.coinone.co.kr/v1/private
KORBIT_PRIVATE_WS_URL=wss://ws-api.korbit.co.kr/v2/private

# Developer-only fallback credentials for manual smoke checks.
# Never proxy user orders, user balances, or user portfolio calls with these values.
UPBIT_TEST_ACCESS_KEY=
UPBIT_TEST_SECRET_KEY=
BITHUMB_TEST_API_KEY=
BITHUMB_TEST_SECRET_KEY=
COINONE_TEST_ACCESS_TOKEN=
COINONE_TEST_SECRET_KEY=
KORBIT_TEST_API_KEY=
KORBIT_TEST_SECRET_KEY=
