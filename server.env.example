DATABASE_URL=postgresql://cryptomts:cryptomts@localhost:5432/cryptomts
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d
PORT=3000
NODE_ENV=development

USE_LIVE_DATA=true
PUBLIC_STREAMING_ENABLED=true
PRIVATE_STREAMING_ENABLED=true

USD_KRW_FALLBACK=1350
FX_BASE_URL=https://api.exchangerate.host
FX_STALE_THRESHOLD_MS=300000
EXCHANGE_RATE_API_KEY=

EXCHANGE_CREDENTIAL_ENCRYPTION_KEY=replace-with-32-byte-secret

UPBIT_REST_BASE_URL=https://api.upbit.com
UPBIT_PUBLIC_WS_URL=wss://api.upbit.com/websocket/v1
UPBIT_PRIVATE_WS_URL=wss://api.upbit.com/websocket/v1/private

BITHUMB_REST_BASE_URL=https://api.bithumb.com
BITHUMB_PUBLIC_WS_URL=wss://pubwss.bithumb.com/pub/ws
BITHUMB_PRIVATE_WS_URL=wss://pubwss.bithumb.com/pub/ws

COINONE_REST_BASE_URL=https://api.coinone.co.kr
COINONE_PUBLIC_WS_URL=wss://stream.coinone.co.kr
COINONE_PRIVATE_WS_URL=wss://stream.coinone.co.kr

KORBIT_REST_BASE_URL=https://api.korbit.co.kr
KORBIT_PUBLIC_WS_URL=wss://ws-api.korbit.co.kr/v2/public
KORBIT_PRIVATE_WS_URL=wss://ws.korbit.co.kr/v1/user/push

BINANCE_REST_BASE_URL=https://api.binance.com
BINANCE_PUBLIC_WS_URL=wss://data-stream.binance.vision/stream
BINANCE_PRIVATE_WS_URL=

