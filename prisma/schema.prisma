generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  authProvider        String               @default("email")
  providerAccountId   String?
  passwordHash        String
  nickname            String
  cash                Float                @default(15000000)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  holdings            Holding[]
  orders              Order[]
  favorites           Favorite[]
  exchangeConnections ExchangeConnection[]
  exchangeConnectionVerifications ExchangeConnectionVerification[]
  orderRequests       OrderRequest[]

  @@unique([authProvider, providerAccountId])
}

model Coin {
  id        String  @id
  symbol    String  @unique
  nameKo    String
  nameEn    String
  basePrice Float
  isActive  Boolean @default(true)
}

model Holding {
  id       String @id @default(uuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  coinId   String
  quantity Float
  avgPrice Float

  @@unique([userId, coinId])
}

model Order {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  coinId    String
  exchange  String
  side      String
  type      String
  price     Float
  quantity  Float
  total     Float
  status    String   @default("filled")
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Favorite {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  coinId String

  @@unique([userId, coinId])
}

model ExchangeConnection {
  id                  String    @id @default(uuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id])
  exchange            String
  label               String?
  apiKeyEncrypted     String
  secretKeyEncrypted  String
  passphraseEncrypted String?
  validationStatus    String    @default("placeholder")
  validationMode      String    @default("placeholder")
  validationCode      String?
  validationMessage   String?
  validationDetails   Json?
  canUsePrivateApi    Boolean   @default(false)
  connectionStatus    String    @default("pending")
  lastValidatedAt     DateTime?
  lastSyncAt          DateTime?
  isTestConnectionResult Boolean @default(false)
  lastErrorCode       String?
  lastErrorSummary    String?
  failureReason       String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  verifications       ExchangeConnectionVerification[]
  orderRequests       OrderRequest[]

  @@unique([userId, exchange])
  @@index([userId, exchange])
}

model ExchangeConnectionVerification {
  id                  String              @id @default(uuid())
  exchangeConnectionId String?
  exchangeConnection  ExchangeConnection? @relation(fields: [exchangeConnectionId], references: [id], onDelete: SetNull)
  userId              String
  user                User                @relation(fields: [userId], references: [id])
  exchange            String
  status              String
  code                String
  message             String
  details             Json?
  checkedAt           DateTime            @default(now())
  createdAt           DateTime            @default(now())

  @@index([userId, exchange, checkedAt])
  @@index([exchangeConnectionId, checkedAt])
}

model OrderRequest {
  id                  String              @id @default(uuid())
  userId              String
  user                User                @relation(fields: [userId], references: [id])
  exchangeConnectionId String?
  exchangeConnection  ExchangeConnection? @relation(fields: [exchangeConnectionId], references: [id], onDelete: SetNull)
  exchange            String
  symbol              String
  side                String
  type                String
  status              String
  providerOrderId     String?
  requestPayload      Json
  responsePayload     Json?
  failureCode         String?
  failureMessage      String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([userId, exchange, createdAt])
  @@index([exchangeConnectionId, createdAt])
}
